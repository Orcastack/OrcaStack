[Unit]
Description=ORCASTACK Gateway Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/lib/orcastack
Environment=ORCASTACK_GATEWAY_HTTP_PORT=8080
Environment=ORCASTACK_GATEWAY_GRPC_PORT=9080
ExecStart=/usr/bin/orcastack serve
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target